# Server Configuration
PORT=8080
LOG_LEVEL=info

# Node.js Backend Configuration
NODEJS_BASE_URL=http://localhost:5007
NODEJS_API_KEY=your-nodejs-api-key-here
NODEJS_TIMEOUT=10s

# API Security
API_KEY=apikey_123456789
RATE_LIMIT=100

# Observability
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# PDF Configuration
PDF_OUTPUT_DIR=/tmp/pdfs
MAX_PDF_SIZE=10485760